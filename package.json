{
  "name": "playwright-testids-good-and-bad",
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "description": "A teaching repo of good and bad data-testid examples, shown in Vitest (React Testing Library) and Playwright.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 5173",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "1.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "25.9.3",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "10.5.0",
    "eslint-plugin-testing-library": "7.16.2",
    "executable-stories-playwright": "8.5.0",
    "executable-stories-vitest": "8.4.0",
    "globals": "17.6.0",
    "jsdom": "^25.0.1",
    "playwright": "1.60.0",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.4",
    "tw-animate-css": "1.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "8.61.1",
    "vite": "7.3.5",
    "vitest": "4.1.8"
  }
}
